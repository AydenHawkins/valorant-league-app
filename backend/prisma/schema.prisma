generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//
// ==================== CORE ENTITIES ====================
//

model Season {
  id        Int       @id @default(autoincrement())
  name      String
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Relationships
  series      Series[]
  teamRosters TeamRoster[]

  @@unique([name])
  @@index([startDate])
}

model Team {
  id        Int      @id @default(autoincrement())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relationships
  rosters          TeamRoster[]
  redSeries        Series[]           @relation("RedTeam")
  blueSeries       Series[]           @relation("BlueTeam")
  teamStats        TeamStats[]
  substitutions    Substitution[]
  roundPlayerStats RoundPlayerStats[]

  @@index([name])
}

model Player {
  id        Int      @id @default(autoincrement())
  name      String
  tag       String
  puuid     String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  rosters    TeamRoster[]
  subIns     Substitution[]     @relation("SubIn")
  subOuts    Substitution[]     @relation("SubOut")
  plants     Plant[]
  defuses    Defuse[]
  roundStats RoundPlayerStats[]

  @@unique([name, tag])
  @@index([name, tag])
}

//
// ==================== MATCH STRUCTURE ====================
//

model Series {
  id        Int       @id @default(autoincrement())
  bestOf    Int
  startDate DateTime
  endDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  // Foreign keys
  seasonId Int
  season   Season @relation(fields: [seasonId], references: [id])

  redTeamId  Int
  redTeam    Team @relation("RedTeam", fields: [redTeamId], references: [id])
  blueTeamId Int
  blueTeam   Team @relation("BlueTeam", fields: [blueTeamId], references: [id])

  maps Match[]

  @@index([seasonId])
  @@index([redTeamId])
  @@index([blueTeamId])
}

model Match {
  id          Int      @id @default(autoincrement())
  mapName     String
  mapNumber   Int
  riotMatchId String?  @unique
  matchDate   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relationships
  seriesId Int
  series   Series @relation(fields: [seriesId], references: [id])

  playerStats   PlayerStats[]
  teamStats     TeamStats[]
  rounds        Round[]
  substitutions Substitution[]

  @@unique([seriesId, mapNumber])
  @@index([mapName])
  @@index([matchDate])
}

//
// ==================== STATS MODELS ====================
//

model PlayerStats {
  id            Int    @id @default(autoincrement())
  kills         Int
  deaths        Int
  assists       Int
  acs           Int
  adr           Float
  hsPercent     Float
  kast          Float
  fkills        Int
  fdeaths       Int
  plants        Int
  defuses       Int
  clutches      Int
  clutchPercent Float
  agent         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Foreign keys
  MatchId Int
  Match   Match @relation(fields: [MatchId], references: [id])

  teamRosterId Int
  teamRoster   TeamRoster @relation(fields: [teamRosterId], references: [id])

  @@unique([teamRosterId, MatchId])
  @@index([MatchId])
  @@index([teamRosterId])
}

model TeamStats {
  id            Int   @id @default(autoincrement())
  attackWins    Int
  defenseWins   Int
  postPlantsWon Int
  roundsPlayed  Int
  roundsWon     Int
  roundsLost    Int
  winPercent    Float

  MatchId Int
  Match   Match @relation(fields: [MatchId], references: [id])

  teamId Int
  team   Team @relation(fields: [teamId], references: [id])

  @@unique([MatchId, teamId])
  @@index([MatchId])
  @@index([teamId])
}

//
// ==================== ROSTERS & SUBS ====================
//

model TeamRoster {
  id        Int       @id @default(autoincrement())
  startDate DateTime  @default(now())
  endDate   DateTime?

  teamId Int
  team   Team @relation(fields: [teamId], references: [id])

  playerId Int
  player   Player @relation(fields: [playerId], references: [id])

  seasonId Int
  season   Season @relation(fields: [seasonId], references: [id])

  playerStats PlayerStats[]

  @@unique([playerId, teamId, seasonId])
  @@index([teamId])
  @@index([playerId])
  @@index([seasonId])
}

model Substitution {
  id               Int      @id @default(autoincrement())
  substitutedInId  Int
  substitutedIn    Player   @relation("SubIn", fields: [substitutedInId], references: [id])
  substitutedOutId Int
  substitutedOut   Player   @relation("SubOut", fields: [substitutedOutId], references: [id])
  teamId           Int
  team             Team     @relation(fields: [teamId], references: [id])
  MatchId          Int
  Match            Match    @relation(fields: [MatchId], references: [id])
  timestamp        DateTime @default(now())

  @@index([MatchId])
  @@index([teamId])
}

//
// ==================== ROUND DATA ====================
//

model Round {
  id           Int     @id @default(autoincrement())
  roundNumber  Int
  result       String
  winningTeam  String
  site         String?
  plantTimeMs  Int?
  defuseTimeMs Int?

  MatchId Int
  Match   Match @relation(fields: [MatchId], references: [id])

  // Relationships
  plant       Plant?
  defuse      Defuse?
  playerStats RoundPlayerStats[]

  @@unique([MatchId, roundNumber])
  @@index([MatchId])
  @@index([winningTeam])
}

model Plant {
  id        Int     @id @default(autoincrement())
  roundId   Int     @unique
  round     Round   @relation(fields: [roundId], references: [id])
  site      String
  playerId  Int?
  player    Player? @relation(fields: [playerId], references: [id])
  timeMs    Int?
  locationX Float?
  locationY Float?

  @@index([playerId])
  @@index([site])
}

model Defuse {
  id        Int     @id @default(autoincrement())
  roundId   Int     @unique
  round     Round   @relation(fields: [roundId], references: [id])
  playerId  Int?
  player    Player? @relation(fields: [playerId], references: [id])
  timeMs    Int?
  locationX Float?
  locationY Float?

  @@index([playerId])
}

model RoundPlayerStats {
  id       Int    @id @default(autoincrement())
  roundId  Int
  round    Round  @relation(fields: [roundId], references: [id])
  playerId Int
  player   Player @relation(fields: [playerId], references: [id])
  teamId   Int
  team     Team   @relation(fields: [teamId], references: [id])

  score            Int
  kills            Int
  deaths           Int?
  assists          Int?
  headshots        Int
  bodyshots        Int
  legshots         Int
  damageDealt      Int
  damageReceived   Int?
  weapon           String?
  armor            String?
  loadoutValue     Int?
  creditsRemaining Int?
  wasAfk           Boolean?
  stayedInSpawn    Boolean?

  @@unique([roundId, playerId])
  @@index([roundId])
  @@index([playerId])
  @@index([teamId])
}
